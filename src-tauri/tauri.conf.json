{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "乘法小天才",
  "version": "1.0.0",
  "identifier": "com.chengfa.xiaotiantian",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "乘法小天才",
        "width": 390,
        "height": 844,
        "minWidth": 360,
        "maxWidth": 1024,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png"
    ]
  }
}
